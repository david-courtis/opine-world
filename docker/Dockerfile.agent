# Claude analyzer/synth agent image
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates bash iproute2 util-linux procps \
    && rm -rf /var/lib/apt/lists/*

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-numpy python3-scipy python3-sympy python3-networkx \
    python3-pil python3-matplotlib python3-pandas python3-sklearn \
    python3-skimage python3-imageio python3-shapely python3-z3 \
    python3-yaml python3-requests python3-tqdm python3-rich \
    && rm -rf /var/lib/apt/lists/*

ARG USER_ID=1000
ARG GROUP_ID=1000
RUN if id ubuntu >/dev/null 2>&1; then userdel -r ubuntu || true; fi \
    && if getent group ubuntu >/dev/null 2>&1; then groupdel ubuntu || true; fi \
    && if getent group ${GROUP_ID} >/dev/null 2>&1; then \
         existing_group="$(getent group ${GROUP_ID} | cut -d: -f1)"; \
       else groupadd -g ${GROUP_ID} user; existing_group="user"; fi \
    && useradd -m -u ${USER_ID} -g ${GROUP_ID} -s /bin/bash user

USER user
WORKDIR /home/user
CMD ["/bin/bash"]
